# ════════════════════════════════════════════════════════════════
#  LuminaLib — Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is gitignored — never commit secrets.
# ════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
POSTGRES_USER=lumina
POSTGRES_PASSWORD=lumina_secret
POSTGRES_DB=luminalib

# ── JWT Auth ─────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage Backend ──────────────────────────────────────────────
# Options: "local" | "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage

# S3 / MinIO (only needed when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=luminalib-books
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── LLM Backend ──────────────────────────────────────────────────
# Options: "ollama" | "openai"
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# OpenAI settings (used when LLM_BACKEND=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Recommendation Engine ────────────────────────────────────────
# Options: "content_based" | "collaborative"
RECOMMENDATION_ALGORITHM=content_based
RECOMMENDATION_TOP_N=10

# ── Pagination ───────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
